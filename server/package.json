    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.72.0"
  }
}
