{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "server",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-05",
	"d1_databases": [
		{
			"binding": "rent_db",
			"database_name": "rent-db",
			"database_id": "331b7833-04ce-4b77-bd5c-87232e1ad4f4",
			"remote": true
		},
	],
	"triggers": {
		"crons": [
			"30 19 * * *",
			"30 3 * * *",
			"30 4 * * *"
		]
	},
}